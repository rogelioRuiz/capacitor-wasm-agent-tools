{
  "name": "capacitor-wasm-agent-tools",
  "version": "0.1.0",
  "description": "Standalone Rust-backed Capacitor plugin for secure sandboxed execution of WebAssembly, JavaScript, and Python on native mobile platforms.",
  "main": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "type": "module",
  "author": "Techxagon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rogelioRuiz/capacitor-wasm-agent-tools.git"
  },
  "homepage": "https://github.com/rogelioRuiz/capacitor-wasm-agent-tools#readme",
  "bugs": {
    "url": "https://github.com/rogelioRuiz/capacitor-wasm-agent-tools/issues"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "build:android": "./scripts/build-android.sh",
    "build:ios": "./scripts/build-ios.sh",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "files": [
    "dist/esm/",
    "android/src/main/",
    "android/build.gradle",
    "ios/Sources/",
    "ios/Frameworks/",
    "CapacitorWasmAgentTools.podspec",
    "Package.swift"
  ],
  "keywords": [
    "capacitor",
    "plugin",
    "rust",
    "uniffi",
    "wasm",
    "webassembly",
    "sandbox",
    "wasmtime",
    "quickjs",
    "javascript",
    "python",
    "rustpython",
    "ai"
  ],
  "peerDependencies": {
    "@capacitor/core": "^7.0.0 || ^8.0.0"
  },
  "devDependencies": {
    "@capacitor/core": "^8.0.0",
    "@changesets/cli": "^2.27.0",
    "typescript": "~5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
